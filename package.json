    "whatsapp-web.js": "1.34.7",
    "zod": "4.2.1"
  },
  "devDependencies": {
    "@types/node": "24.10.2",
    "@types/qrcode": "1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "prisma": "6.19.3",
    "tsx": "4.22.4",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
