generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  OWNER
  TENANT_ADMIN
}

enum WhatsAppStatus {
  DISCONNECTED
  QR_READY
  AUTHENTICATED
  CONNECTED
  FAILED
}

enum AppointmentStatus {
  BOOKED
  CANCELLED
  COMPLETED
  NO_SHOW
}

enum AppointmentSource {
  WHATSAPP
  PANEL
}

enum ReminderKind {
  DAY_BEFORE
  TWO_HOURS_BEFORE
}

enum ReminderStatus {
  PENDING
  PROCESSING
  SENT
  SKIPPED
  FAILED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model Tenant {
  id                String              @id @default(cuid())
  name              String
  slug              String              @unique
  phone             String?
  address           String?
  timezone          String              @default("Europe/Istanbul")
  greetingMessage   String              @default("Merhaba! Size hemen yardimci olabilirim.")
  afterHoursMessage String              @default("Su an kapaliyiz ama buradan hemen randevu alabilirsiniz.")
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  users             User[]
  whatsappSession   WhatsAppSession?
  services          Service[]
  staff             Staff[]
  workingHours      WorkingHour[]
  customers         Customer[]
  appointments      Appointment[]
  conversationStates ConversationState[]
  messageLogs       MessageLog[]
}

model User {
  id           String    @id @default(cuid())
  tenantId     String?
  email        String    @unique
  passwordHash String
  role         UserRole
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  tenant       Tenant?   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model WhatsAppSession {
  id             String         @id @default(cuid())
  tenantId       String         @unique
  status         WhatsAppStatus @default(DISCONNECTED)
  qrCode         String?
  qrDataUrl      String?
  pairingCodePhone String?
  pairingCode    String?
  connectedPhone String?
  lastSeenAt     DateTime?
  lastError      String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Service {
  id              String        @id @default(cuid())
  tenantId        String
  name            String
  durationMinutes Int
  priceCents      Int           @default(0)
  active          Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  appointments    Appointment[]

  @@index([tenantId, active])
}

model Staff {
  id           String        @id @default(cuid())
  tenantId     String
  name         String
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  workingHours WorkingHour[]
  appointments Appointment[]

  @@index([tenantId, active])
}

model WorkingHour {
  id          String   @id @default(cuid())
  tenantId    String
  staffId     String
  weekday     Int
  startMinute Int
  endMinute   Int
  closed      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  staff       Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, weekday])
  @@index([tenantId, weekday])
}

model Customer {
  id            String         @id @default(cuid())
  tenantId      String
  phone         String
  name          String?
  lastMessageAt DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  notes         CustomerNote[]
  appointments  Appointment[]

  @@unique([tenantId, phone])
  @@index([tenantId, updatedAt])
}

model CustomerNote {
  id         String   @id @default(cuid())
  tenantId   String
  customerId String
  note       String
  createdAt  DateTime @default(now())

  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerId, createdAt])
}

model Appointment {
  id             String            @id @default(cuid())
  tenantId       String
  customerId     String
  staffId        String
  serviceId      String
  startAt        DateTime
  endAt          DateTime
  status         AppointmentStatus @default(BOOKED)
  source         AppointmentSource @default(WHATSAPP)
  cancelReason   String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer       Customer          @relation(fields: [customerId], references: [id], onDelete: Cascade)
  staff          Staff             @relation(fields: [staffId], references: [id], onDelete: Restrict)
  service        Service           @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  reminders      Reminder[]

  @@index([tenantId, startAt])
  @@index([tenantId, staffId, startAt, endAt])
  @@index([tenantId, customerId, status])
}

model Reminder {
  id            String         @id @default(cuid())
  appointmentId String
  kind          ReminderKind
  dueAt         DateTime
  sentAt        DateTime?
  status        ReminderStatus @default(PENDING)
  lockedAt      DateTime?
  lockedBy      String?
  attemptCount  Int            @default(0)
  lastError     String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  appointment   Appointment    @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@unique([appointmentId, kind])
  @@index([status, dueAt])
  @@index([lockedBy, lockedAt])
}

model ConversationState {
  id            String   @id @default(cuid())
  tenantId      String
  customerPhone String
  state         String
  payload       Json
  expiresAt     DateTime
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, customerPhone])
  @@index([expiresAt])
}

model MessageLog {
  id          String           @id @default(cuid())
  tenantId    String
  customerPhone String
  direction   MessageDirection
  body        String
  createdAt   DateTime         @default(now())

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, customerPhone, createdAt])
}
